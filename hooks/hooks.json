{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/alexzh/jadecli-ecosystem/scripts/session-init.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/alexzh/jadecli-ecosystem/scripts/access-guard.sh"
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[task-created] $(echo $HOOK_INPUT | jq -r '.tool_input.subject // \"untitled\"')\" >> /tmp/jadecli-tasks.log"
          }
        ]
      }
    ]
  }
}
