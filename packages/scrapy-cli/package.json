{
  "name": "@jadecli/scrapy-cli",
  "version": "0.1.0",
  "description": "TypeScript directives and primitives SDK for Scrapy spider management",
  "type": "module",
  "bin": {
    "scrapy-cli": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./directives": "./dist/directives/index.js",
    "./primitives": "./dist/primitives/index.js",
    "./generators": "./dist/generators/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "tsx": "^4.19.0",
    "@types/node": "^22.0.0"
  }
}
